---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    slug: '/lab/',
    label: 'Lab',
    heading: 'Projects & Tools',
    body: 'D3 visualizations, AI hallucination research, grant processing tools, and evidence synthesis dashboards.',
  },
  {
    slug: '/writing/',
    label: 'Writing',
    heading: 'Essays & Articles',
    body: "On cognition, AI, organizations, policy, and whatever I can't stop thinking about. Here, on LinkedIn, and on Substack.",
  },
  {
    slug: '/consulting/',
    label: 'Consulting',
    heading: 'Organizational Diagnostics',
    body: 'Validated psychological measurement applied to real problems. Not surveys for the sake of surveys. Signal that informs decisions.',
  },
  {
    slug: '/about/',
    label: 'About',
    heading: 'Background',
    body: 'PhD in cognitive psychology. Researcher, founder, research administrator, and consultant in roughly that order.',
  },
];
---

<BaseLayout title="JZ Stafura">
  <section class="hero">
    <h1>JZ Stafura</h1>
    <p class="tagline">Cognitive Science. Research Administration. Education.</p>
    <div class="external-links">
      <a href="https://www.linkedin.com/in/jzstafura" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://scholar.google.com/citations?user=F6LcYIoAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>
      <a href="https://github.com/jzstafura" target="_blank" rel="noopener">GitHub</a>
    </div>
  </section>

  <section class="sections-grid">
    {sections.map((s) => (
      <a href={s.slug} class="section-card">
        <span class="section-label">{s.label}</span>
        <h2>{s.heading}</h2>
        <p>{s.body}</p>
        <span class="section-arrow">&rarr;</span>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0 3.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: normal;
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }

  .tagline {
    color: var(--color-muted);
    font-size: 1.1rem;
    font-style: italic;
    margin-bottom: 2rem;
  }

  .external-links {
    display: flex;
    gap: 1.75rem;
  }

  .external-links a {
    font-size: 0.875rem;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2px;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  .external-links a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .sections-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    margin-top: 3.5rem;
  }

  .section-card {
    background: var(--color-bg);
    padding: 2.25rem 2rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.15s;
    position: relative;
  }

  .section-card:hover {
    background: #fff;
  }

  .section-card:hover h2 {
    color: var(--color-accent);
  }

  .section-card:hover .section-arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .section-card h2 {
    font-size: 1.2rem;
    font-weight: normal;
    margin: 0;
    transition: color 0.15s;
  }

  .section-card p {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
    flex-grow: 1;
  }

  .section-arrow {
    font-size: 1rem;
    color: var(--color-border);
    margin-top: 0.75rem;
    display: inline-block;
    transition: transform 0.15s, color 0.15s;
  }

  @media (max-width: 560px) {
    .sections-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
