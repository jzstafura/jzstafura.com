---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Consulting — JZ Stafura"
  description="Validated psychological measurement applied to real organizational problems."
>

  <section class="temp">
    <p class="overline">Consulting</p>
    <h1>Know <em>why</em><br>before you decide.</h1>
    <p class="sub">More here soon.</p>
    <a href="mailto:jz@jzstafura.com" class="cta-btn">Start a Conversation →</a>
  </section>

</BaseLayout>

<style>
  .temp {
    padding: 6rem 0;
    text-align: center;
  }

  .overline {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: normal;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  h1 em {
    font-style: italic;
    color: var(--color-accent);
  }

  .sub {
    color: var(--color-muted);
    margin-bottom: 2.5rem;
  }

  .cta-btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.75rem 1.75rem;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .cta-btn:hover { opacity: 0.85; text-decoration: none; }
</style>
