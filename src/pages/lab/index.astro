---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Intellectual Network Map',
    slug: 'intellectual-map',
    status: 'Live',
    statusClass: 'status-live',
    description: 'Interactive visualization of 450+ books organized by core intellectual problems rather than academic disciplines. Maps connections across 8 fundamental domains and surfaces bridge authors who span multiple territories.',
    tags: ['D3.js', 'NetworkX', 'Plotly', 'Wikipedia API'],
    liveUrl: 'https://jzstafura-lab.github.io/intellectual-map/',
  },
  {
    title: 'Hallucination Detection',
    slug: 'hallucinations',
    status: 'Active Research',
    statusClass: 'status-research',
    description: 'A Python pipeline for detecting and analyzing AI-hallucinated citations in published academic papers. Tests three hypotheses: author expertise distance, field publication velocity, and section location effects.',
    tags: ['Python', 'CrossRef API', 'GPTZero', 'Statistical Analysis', 'Quarto'],
    liveUrl: 'https://jzstafura-lab.github.io/hallucitation-detection/',
  },
  {
    title: 'NOFO Processor',
    slug: 'nofo-processor',
    status: 'Tool',
    statusClass: 'status-tool',
    description: 'AI-powered grant solicitation analysis. Extracts deadlines, eligibility, budget constraints, and submission limits from NOFOs and RFAs. Generates preparation timelines, flags critical issues, and produces modular PI summaries.',
    tags: ['Claude API', 'React', 'Grants Management'],
    liveUrl: null,
  },
  {
    title: 'Violence Research Dashboard',
    slug: 'violence-dashboard',
    status: 'Live',
    statusClass: 'status-live',
    description: 'Interactive evidence synthesis dashboard exploring cognitive, social, and ecological factors underlying interpersonal violence. Visualizes patterns across the research literature to support prevention and intervention.',
    tags: ['R', 'Quarto', 'Evidence Synthesis', 'Data Visualization'],
    liveUrl: 'https://jzstafura-lab.github.io/projects/violence/dashboard/',
  },
];
---

<BaseLayout
  title="Lab - JZ Stafura"
  description="Research projects, tools, and visualizations from JZ Stafura."
>
  <section class="hero">
    <p class="overline">Lab</p>
    <h1>Projects &amp; Tools</h1>
    <p class="hero-sub">Research infrastructure, data tools, and interactive visualizations built at the intersection of cognitive science, AI, and data.</p>
    <div class="external-links">
      <a href="https://github.com/JZStafura-Lab" target="_blank" rel="noopener">GitHub &#x2197;</a>
      <a href="https://jzstafura-lab.github.io" target="_blank" rel="noopener">JAB Lab &#x2197;</a>
    </div>
  </section>

  <section class="grid">
    {projects.map((project) => (
      <div class="card">
        <div class="card-header">
          <span class={'status ' + project.statusClass}>{project.status}</span>
          {project.liveUrl && (
            <a
              href={project.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="live-link"
            >
              View Live &#x2197;
            </a>
          )}
        </div>
        <h2>
          <a href={'/lab/' + project.slug + '/'} class="card-link">{project.title}</a>
        </h2>
        <p>{project.description}</p>
        <div class="tags">
          {project.tags.map(tag => <span>{tag}</span>)}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  .overline { font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 0.75rem; }
  .hero { padding: 4rem 0 3rem; border-bottom: 1px solid var(--color-border); margin-bottom: 3rem; }
  .hero h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: normal; margin-bottom: 0.75rem; }
  .hero-sub { max-width: 55ch; color: var(--color-muted); margin-bottom: 1.5rem; }
  .external-links { display: flex; gap: 1.5rem; }
  .external-links a { font-size: 0.875rem; color: var(--color-muted); border-bottom: 1px solid var(--color-border); padding-bottom: 2px; }
  .external-links a:hover { color: var(--color-accent); text-decoration: none; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 1.5rem; }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    background: white;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 12px rgba(37, 99, 235, 0.08);
  }

  .card-header { display: flex; align-items: center; justify-content: space-between; min-height: 1.5rem; }

  .status { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.55rem; border: 1px solid; }
  .status-live { color: #16a34a; border-color: rgba(22, 163, 74, 0.3); background: rgba(22, 163, 74, 0.05); }
  .status-research { color: #d97706; border-color: rgba(217, 119, 6, 0.3); background: rgba(217, 119, 6, 0.05); }
  .status-tool { color: var(--color-accent); border-color: rgba(37, 99, 235, 0.3); background: rgba(37, 99, 235, 0.05); }

  .live-link { font-size: 0.75rem; color: var(--color-muted); text-decoration: none; border-bottom: 1px solid var(--color-border); padding-bottom: 1px; }
  .live-link:hover { color: var(--color-accent); text-decoration: none; }

  .card h2 { font-size: 1.15rem; font-weight: normal; margin: 0; }

  .card-link {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .card:hover .card-link { color: var(--color-accent); }

  .card p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.7; flex-grow: 1; margin: 0; }

  .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.25rem; }
  .tags span { font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-muted); border: 1px solid var(--color-border); padding: 0.15rem 0.45rem; }

  @media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
</style>
