---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SourceToScalp from '../../../components/educational/SourceToScalp.jsx';
---

<BaseLayout
  title="Source to Scalp: The EEG Forward Problem — JZ Stafura"
  description="An interactive demonstration of how a cortical current dipole projects to scalp electrodes. Drag the source, rotate its orientation, and toggle skull blurring to see why scalp EEG is spatially smeared and why radial vs. tangential dipoles produce different topographies."
>
  <div class="full-bleed">
    <SourceToScalp client:load />
  </div>
</BaseLayout>

<style>
  :global(main) {
    padding: 0 !important;
    max-width: none !important;
  }
  .full-bleed {
    width: 100%;
  }
</style>
