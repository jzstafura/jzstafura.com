---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ErpLanguage from '../../../components/educational/ErpLanguage.jsx';
---

<BaseLayout
  title="Language ERPs: N400 & P600 — JZ Stafura"
  description="An interactive visualization of N400 and P600 language ERPs — animated waveforms for congruent, semantic-violation, and syntactic-violation conditions with clickable component detail cards."
>
  <div class="full-bleed">
    <ErpLanguage client:load />
  </div>
</BaseLayout>

<style>
  :global(main) {
    padding: 0 !important;
    max-width: none !important;
  }
  .full-bleed {
    width: 100%;
  }
</style>
